    {
      "parameters": {
        "jsCode": "const item = $input.item.json;\n\n// ===== 1. EARTHQUAKE SCORING =====\nlet earthquakeScore = 0;\nlet earthquakeDetails = \"None\";\nif (item.features && item.features.length > 0) {\n  // sabse bada magnitude wala event le\n  const strongest = item.features.reduce((max, f) =>\n    f.properties.mag > max.properties.mag ? f : max\n  );\n  const mag = strongest.properties.mag;\n  earthquakeScore = Math.min(10, (mag / 7) * 10); // mag 7 = score 10\n  earthquakeDetails = `Magnitude ${mag} at ${strongest.properties.place || 'nearby'}`;\n}\n\n// ===== 2. WEATHER SCORING =====\nlet weatherScore = 0;\nlet weatherDetails = \"Normal\";\nif (item.wind && item.main) {\n  const windSpeed = item.wind.speed || 0; // m/s\n  const condition = item.weather && item.weather[0] ? item.weather[0].main : \"\";\n  const rain1h = item.rain ? item.rain[\"1h\"] || 0 : 0;\n\n  let windScore = Math.min(10, (windSpeed / 20) * 10); // 20 m/s = score 10\n  let rainScore = Math.min(10, (rain1h / 30) * 10); // 30mm/hr = score 10\n  let stormBonus = (condition === \"Thunderstorm\") ? 4 : 0;\n\n  weatherScore = Math.min(10, Math.max(windScore, rainScore) + stormBonus);\n  weatherDetails = `${condition}, wind ${windSpeed}m/s, rain ${rain1h}mm`;\n}\n\n// ===== 3. FIRE SCORING =====\nlet fireScore = 0;\nlet fireDetails = \"None detected\";\nif (item.data && typeof item.data === \"string\") {\n  const lines = item.data.trim().split(\"\\n\").filter(l => l.trim().length > 0);\n  const fireCount = Math.max(0, lines.length - 1); // minus header row\n  fireScore = Math.min(10, fireCount * 2); // har detection +2, max 10\n  if (fireCount > 0) fireDetails = `${fireCount} fire detection(s)`;\n}\n\n// ===== 4. WEIGHTED FINAL RISK SCORE =====\nconst riskScore = (\n  0.4 * earthquakeScore +\n  0.35 * weatherScore +\n  0.25 * fireScore\n).toFixed(1);\n\nreturn {\n  json: {\n    city: item.city || item.name || \"Unknown\",\n    timestamp: new Date().toISOString(),\n    earthquake_score: earthquakeScore.toFixed(1),\n    earthquake_details: earthquakeDetails,\n    weather_score: weatherScore.toFixed(1),\n    weather_details: weatherDetails,\n    fire_score: fireScore.toFixed(1),\n    fire_details: fireDetails,\n    risk_score: parseFloat(riskScore)\n  }\n};"
      },
