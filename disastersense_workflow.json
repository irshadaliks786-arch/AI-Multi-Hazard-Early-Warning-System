      "parameters": {
        "jsCode": "const lat = parseFloat($input.item.json.lat);\nconst lon = parseFloat($input.item.json.long);\nconst radiusKm = parseFloat($input.item.json.radius_km);\n\n// 1 degree latitude ≈ 111 km\nconst offset = radiusKm / 111;\n\nconst west = lon - offset;\nconst east = lon + offset;\nconst south = lat - offset;\nconst north = lat + offset;\n\nreturn {\n  json: {\n    ...$input.item.json,\n    west: west.toFixed(4),\n    south: south.toFixed(4),\n    east: east.toFixed(4),\n    north: north.toFixed(4)\n  }\n};"
      },
